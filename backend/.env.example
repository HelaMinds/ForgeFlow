# ============================================================
# LLM PROVIDER  —  options: openai | google | anthropic | huggingface
# ============================================================
LLM_PROVIDER=openai

# --- OpenAI ---
# Models: gpt-4o | gpt-4o-mini | gpt-4-turbo | o1 | o1-mini
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- Google AI Studio (Gemini) ---
# Models: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro | gemini-flash-latest | gemini-2.0-flash
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GOOGLE_MODEL=gemini-2.5-flash-lite

# --- Anthropic (Claude) ---
# Models: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8 | claude-opus-4-7
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Hugging Face (Inference Router, OpenAI-compatible) ---
# Models: meta-llama/Llama-3.3-70B-Instruct | Qwen/Qwen2.5-72B-Instruct | mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

PORT=4000
